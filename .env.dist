# Secret attendu par collaboratif-client-api (via @ign/mobile-core)
VITE_SECRET=a_super_hidden_secret

# API collaboratif (AuthManager) — chemin gcms requis pour OAuth / user/me
VITE_BASE_API_URL=https://espacecollaboratif.ign.fr/gcms/api/

# OAuth 2 + PKCE — connexion SSO
VITE_OAUTH_CLIENT_ID=
VITE_OAUTH_BASE_URL=
VITE_OAUTH_ANDROID_REDIRECT_URI=fr.ign.gdp://auth/callback
VITE_OAUTH_IOS_REDIRECT_URI=fr.ign.gdp://auth/callback
# En dev web : enregistrer cette URI exacte côté Keycloak
VITE_OAUTH_WEB_REDIRECT_URI=http://localhost:5173/auth/callback
# En dev web, les appels /token passent par le proxy Vite /__sso (pas de config supplémentaire).

# Qualification — build sous un sous-chemin (npm run build:qualif, voir .env.qualif.dist)
# VITE_BASE_PATH=/qlf-gdp/
# VITE_USE_QUALIF=true
# VITE_OAUTH_WEB_REDIRECT_URI=<url-qualif>/qlf-gdp/auth/callback

# Auth obligatoire au démarrage (false = accès direct à la carte)
# VITE_AUTH_REQUIRED=true

# WFS privé Géoplateforme — flux géodésie GDP (couche vectorielle, mode expert)
# VITE_GEODESY_WFS_API_KEY=

# WMTS privé Géoplateforme — fonds Cartes IGN et SCAN 25 Touristique
# Par défaut : ign_scan_ws
# VITE_GEOPORTAIL_SCAN_API_KEY=

# Signalements EspaceCo
# VITE_GDP_REPORT_COMMUNITY_ID=
# VITE_GDP_REPORT_THEME=gdp-tools
