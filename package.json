{
  "name": "gdp-mobile",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:qualif": "tsc -b && vite build --mode qualif && cp scripts/htaccess-qualif.example dist/.htaccess",
    "build:mobile": "VITE_GEODESY_SOURCE=dist tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:qualif": "vite preview --mode qualif",
    "generate-apk": "bash ./scripts/generate-apk.sh",
    "setup-android": "bash ./scripts/setup-android.sh",
    "capacitor-build": "npm run build:mobile && npx cap sync android",
    "capacitor-run-android": "npm run capacitor-build && npx cap run android",
    "open-android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/device": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/preferences": "^8.0.0",
    "@ign/gdp-tools": "*",
    "@ign/mobile-core": "git+ssh://git@github.com/IGNF/mobile-core.git#main",
    "@ign/mobile-device": "git+ssh://git@github.com/IGNF/mobile-device.git#main",
    "@ionic/react": "^8.8.14",
    "collaboratif-client-api": "github:IGNF/collaboratif-client-api#2.0",
    "ionicons": "^8.0.13",
    "ol": "^10.9.0",
    "ol-ext": "^4.0.38",
    "proj4": "^2.20.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "vite-plugin-svgr": "^5.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/ol-ext": "npm:@siedlerchr/types-ol-ext@^3.6.8",
    "@types/proj4": "^2.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
